{
  "private": true,
  "name": "bajarko",
  "version": "1.0.0",
  "devDependencies": {
    "ts-node": "^10.9.2",
    "turbo": "^2.3.3",
    "typescript": "^5.8.3"
  },
  "bin": {
    "bajarko-exec": "./index.js"
  },
  "packageManager": "yarn@3.2.1",
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/modules/*"
  ],
  "scripts": {
    "bajarko-exec": "turbo run dev",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "build:backend": "turbo run build",
    "format": "turbo run format",
    "lint": "turbo run lint",
    "codegen": "cd .",
    "generate:oas": "turbo run generate:oas"
  }
}
